
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * KEDAULATAN AKSES PUBLIK (GUEST ACCESS)
     * Mengizinkan warga non-login membaca pilar informasi publik.
     */
    match /news/{newsId} { allow read: if true; }
    match /settings/contact { allow read: if true; }
    match /testimonials/{testiId} { allow read: if true; }
    match /products/{prodId} { allow read: if true; }
    match /users/{userId} { allow read: if true; }

    /**
     * KEDAULATAN DATA MUTLAK (DEVELOPMENT MODE)
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * BENTENG OTP (SOP PRIVACY)
     */
    match /otp_requests/{requestId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null; 
      allow update, delete: if false;
    }
  }
}
